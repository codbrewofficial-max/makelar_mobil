{
  "info": {
    "_postman_id": "8f2c1a10-0000-4000-8000-suhumobilapi01",
    "name": "SuhuMobil Backend API",
    "description": "Koleksi endpoint REST API SuhuMobil sesuai 04-api-contract.md. Autentikasi admin memakai JWT via HttpOnly Cookie (Postman otomatis menyimpan & mengirim cookie per domain, jadi cukup jalankan 'Auth > Login' sekali sebelum request 🔒 admin lainnya).\n\nBase URL diatur lewat environment variable {{baseUrl}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin/Owner)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login admin/owner. Cookie JWT HttpOnly otomatis di-set oleh backend dan disimpan oleh Postman cookie jar untuk domain baseUrl.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "  pm.environment.set('userId', json.data.id);",
                  "  pm.environment.set('userRole', json.data.role);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
